@page "/counter"
@rendermode InteractiveServer

<PageTitle>Counter</PageTitle>

<h1>Counter</h1>

<p role="status">Current count: @currentCount</p>
<p>Number: @_number</p>

<button class="btn btn-primary" @onclick="IncrementCount">Click me</button>

@code {
    private int currentCount = 0;
    private readonly int _id = Random.Shared.Next(1000, 9999);
    private readonly int _number = Random.Shared.Next(1, 10000);

    public Counter()
    {
        Console.WriteLine($"CTOR {_id}");
        Console.WriteLine($"CTOR {_number}");
    }

    private void IncrementCount()
    {
        currentCount++;
    }

    protected override void OnAfterRender(bool firstRender)
    {
        Console.WriteLine($"RENDER {_id} First={firstRender}");
    }

    protected override void OnInitialized()
    {
        Console.WriteLine($"INIT {_id}");
    }

    protected override void OnParametersSet()
    {
        Console.WriteLine($"PARAMS {_id}");
    }
}
